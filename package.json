{
  "name": "chat-app",
  "private": true,
  "workspaces": [
    "frontend",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev --workspace=server\"",
    "build:frontend": "npm run build --workspace=frontend",
    "start:server": "npm run start --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
